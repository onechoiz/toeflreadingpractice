{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with credits and role.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "credits": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "email", "role", "credits"]
    },
    "CreditRequest": {
      "title": "Credit Request",
      "description": "User request for more credits.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "amount": { "type": "integer" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userEmail", "status", "createdAt"]
    },
    "RedeemKey": {
      "title": "Redeem Key",
      "description": "Key to redeem credits.",
      "type": "object",
      "properties": {
        "key": { "type": "string" },
        "value": { "type": "integer" },
        "used": { "type": "boolean" },
        "usedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["key", "value", "used", "createdAt"]
    },
    "CustomTask": {
      "title": "Custom Task",
      "description": "Admin generated task.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["academic", "everyday", "vocabulary"] },
        "data": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "type", "data", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/requests/{requestId}": {
      "schema": "CreditRequest",
      "description": "Credit requests from users."
    },
    "/keys/{keyId}": {
      "schema": "RedeemKey",
      "description": "Redeemable keys."
    },
    "/customTasks/{taskId}": {
      "schema": "CustomTask",
      "description": "Admin generated tasks."
    }
  }
}
